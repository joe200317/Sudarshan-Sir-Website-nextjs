PORT=4000
# Working MongoDB Atlas URI required (no memory fallback)
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/mindtrainer?retryWrites=true&w=majority
AUTH_SECRET=change-me-to-a-long-random-secret-key
FRONTEND_URL=http://localhost:3000

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_S3_BUCKET=
AWS_S3_PUBLIC_URL=
PUBLIC_BASE_URL=http://localhost:4000

# Razorpay (required when workshop "Include payment" is checked)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# WhatsApp thank-you after form submit (pick one)
# Meta Cloud API:
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# Optional approved template (else plain text — needs 24h window)
WHATSAPP_TEMPLATE_NAME=
WHATSAPP_TEMPLATE_LANG=en
# Or custom provider webhook (Interakt / WATI / etc.):
WHATSAPP_WEBHOOK_URL=

# SMTP — email workshop owner when a lead registers on their slug
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
